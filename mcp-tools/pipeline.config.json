    "outputMultiplicity": "per-namespace",
    "localCommand": "./start-only.sh <namespace> 6",
    "ciCommand": "dotnet run --project mcp-tools/DocGeneration.PipelineRunner -- --namespace <namespace> --steps 6"
  },
  {
    "id": 7,
    "name": "Validate article health",
    "schemaVersion": "1.0",
    "scope": "namespace",
    "dependencies": [4],
