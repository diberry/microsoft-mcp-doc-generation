{
  "name": "test-npm-azure-mcp",
  "version": "1.0.0",
  "description": "Azure MCP CLI metadata extractor — provides tool data for the documentation generation pipeline",
  "private": true,
  "scripts": {
    "start": "az login",
    "start:info": "azmcp server info",
    "start:help": "azmcp --help",
    "start:list": "azmcp tools list",
    "get:version": "azmcp --version",
    "get:tools-json": "azmcp tools list",
    "get:tools-namespace": "azmcp tools list --namespace-mode",
    "get:subscriptions": "azmcp subscription list",
    "get:chat-completion": "bash chat-completion.sh",
    "validate": "node validate-cli-output.js",
    "generate:report": "node generate-report.js",
    "test:report": "node --test test/generate-report.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/mcp": "^2.0.0-beta.31"
  }
}
